Inter = 'Inter'

@font-face {
	font-family: 'Inter';
	src: url('./assets/fonts/Inter/Inter24pt-Black.eot');
	src: url('./assets/fonts/Inter/Inter24pt-Black.eot?#iefix') format('embedded-opentype'),
		url('./assets/fonts/Inter/Inter24pt-Black.woff2') format('woff2'),
		url('./assets/fonts/Inter/Inter24pt-Black.woff') format('woff'),
		url('./assets/fonts/Inter/Inter24pt-Black.ttf') format('truetype');
	font-weight: 900;
	font-style: normal;
	font-display: swap;
}
