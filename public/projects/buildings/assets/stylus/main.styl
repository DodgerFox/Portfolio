#app, main {
  width: 100%;
  min-height: 100vh;
}

a,
.green {
  text-decoration: none;
  color: hsla(160, 100%, 37%, 1);
  transition: 0.4s;
  padding: 3px;
}

.wrap
  width 100%
  max-width 1400px
  padding 0 40px
  margin 0 auto
  @media screen and (max-width: 900px) {
    padding 0 20px
  }


section
  width: 100%
  padding: 90px 0

.section 
  &-title
    font-size 40px
    font-weight 600
    color black
    text-align center
    @media screen and (max-width: 900px)
      font-size 32px
    @media screen and (max-width: 640px)
      font-size 26px
      line-height 30px
  
  &-subtitle
    font-size 26px
    font-weight 500
    color #A5A5A5
    padding-bottom 10px
    text-align center
    @media screen and (max-width: 900px)
      font-size 20px
    @media screen and (max-width: 640px)
      font-size 18px
  
  &-body
    padding-top 50px